/// Demande de secret externe (Phase 9). Un user DEV+ crée la demande,
/// reçoit un lien `<vault>/request/<token>` à transmettre au tiers
/// (qui n'a pas de compte Physalis). Le tiers chiffre son secret côté
/// navigateur via ECDH P-256 + AES-GCM puis le poste — Physalis stocke
/// le ciphertext sans pouvoir le déchiffrer (sauf si l'admin sauvegarde
/// sa clé privée dans son coffre, qui est lui-même chiffré au repos).
///
/// Lien one-shot : invalidé après soumission OU 48h.
model SecretRequest {
  id                 String        @id @default(cuid())
  /// SHA-256 du token brut (`sv_extreq_<32hex>`). Le brut n'est jamais stocké.
  tokenHash          String        @unique
  /// Label visible par le destinataire (ex: "Clé API Stripe production").
  label              String
  /// Description optionnelle, visible par le destinataire.
  description        String?
  /// Auteur de la demande (FK SetNull pour conserver la trace).
  requestedById      String?
  requestedBy        User?         @relation("secretRequestCreator", fields: [requestedById], references: [id], onDelete: SetNull)
  /// Email auteur dénormalisé (subsiste après suppression de l'user).
  requestedByEmail   String
  /// Email destinataire optionnel — si rempli, envoi auto via Mailgun.
  recipientEmail     String?
  /// Org propriétaire de la demande (Cascade : delete org → delete requests).
  organizationId     String
  organization       Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Cible projet optionnelle (SetNull pour garder la trace même après
  /// suppression du projet — l'import devient impossible mais l'audit reste).
  projectId          String?
  project            Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  /// Nom de l'environnement cible (string, pas FK — l'env peut être renommé).
  environmentName    String?
  /// Clé .env cible (ex: "STRIPE_SECRET_KEY"). Validée à l'import contre /^[A-Z][A-Z0-9_]*$/.
  secretKey          String?
  /// Clé publique ECDH P-256 sérialisée JWK. Stockée à la création,
  /// jamais sensible (publique par essence).
  publicKeyJwk       String
  /// Ciphertext base64 (AES-GCM). Vide tant que non soumis. Effacé après import/revoke.
  encryptedSecret    String?
  /// IV AES-GCM base64. Idem.
  secretIv           String?
  /// Clé publique éphémère du client (JWK). Idem — le serveur en a besoin
  /// pour donner à l'admin de quoi dériver la clé symétrique au moment du reveal.
  ephemeralPublicKey String?
  submittedAt        DateTime?
  /// IP du soumetteur (audit, abuse-tracking).
  submitterIp        String?
  /// TTL strict 48h depuis createdAt.
  expiresAt          DateTime
  viewedAt           DateTime?
  importedAt         DateTime?
  revokedAt          DateTime?
  createdAt          DateTime      @default(now())

  @@index([organizationId])
  @@index([projectId])
  @@index([expiresAt])
}

// ─── Modèles fusionnés depuis le schéma admin du SaaS ─────────────────
// En self-host single-tenant, le concept de Client est dégénéré (1 row).
// Les modèles Subscription/AuditLog sont conservés pour ne pas casser le
// code, mais sont peu utilisés en self-host.

model Client {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String         @db.VarChar(255)
  slug             String         @unique @db.VarChar(100)
  plan             Plan           @default(DEDICATED)
  maxOrgs          Int            @default(99) @map("max_orgs")
  maxUsers         Int            @default(999) @map("max_users")
  status           ClientStatus   @default(ACTIVE)
  trialEndsAt      DateTime?      @map("trial_ends_at")
  comped           Boolean        @default(true)
  compedReason     String?        @map("comped_reason") @db.VarChar(255)
  stripeCustomerId String?        @map("stripe_customer_id") @db.VarChar(255)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @default(now()) @map("updated_at")
  subscriptions   Subscription[]
  auditLogs       AuditLog[]
}

model Subscription {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId             String             @map("client_id") @db.Uuid
  client               Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plan                 Plan
  status               SubscriptionStatus
  stripeSubscriptionId String?            @map("stripe_subscription_id") @db.VarChar(255)
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")

  @@index([clientId])
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String?  @map("client_id") @db.Uuid
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  action    String   @db.VarChar(255)
  actor     String   @db.VarChar(255)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([clientId, createdAt])
  @@index([action, createdAt])
}

enum Plan {
  FREE
  SHARED
  DEDICATED
}

enum ClientStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
}

model TokenIndex {
  tokenHash  String    @id @map("token_hash")
  tenantSlug String    @map("tenant_slug") @db.VarChar(100)
  kind       TokenKind
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([tenantSlug, kind])
}

enum TokenKind {
  MACHINE
  PLUGIN
  SHARE
  SECRET_REQUEST
  USER
  ORG
}

model PasswordResetToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  tenantSlug String?   @map("tenant_slug") @db.VarChar(100)
  userId     String    @map("user_id")
  email      String    @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
}

model OidcPolicy {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  repo          String
  workflow      String
  branch        String
  tenantSlug    String   @map("tenant_slug") @db.VarChar(100)
  projectId     String   @map("project_id")
  environmentId String   @map("environment_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([repo, workflow, branch, tenantSlug, projectId, environmentId])
  @@index([repo, workflow, branch])
  @@index([tenantSlug, projectId])
}
