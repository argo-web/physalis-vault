/// Demande de secret externe (Phase 9). Un user DEV+ crée la demande,
/// reçoit un lien `<vault>/request/<token>` à transmettre au tiers
/// (qui n'a pas de compte Physalis). Le tiers chiffre son secret côté
/// navigateur via ECDH P-256 + AES-GCM puis le poste — Physalis stocke
/// le ciphertext sans pouvoir le déchiffrer (sauf si l'admin sauvegarde
/// sa clé privée dans son coffre, qui est lui-même chiffré au repos).
///
/// Lien one-shot : invalidé après soumission OU 48h.
model SecretRequest {
  id                 String        @id @default(cuid())
  /// SHA-256 du token brut (`sv_extreq_<32hex>`). Le brut n'est jamais stocké.
  tokenHash          String        @unique
  /// Label visible par le destinataire (ex: "Clé API Stripe production").
  label              String
  /// Description optionnelle, visible par le destinataire.
  description        String?
  /// Auteur de la demande (FK SetNull pour conserver la trace).
  requestedById      String?
  requestedBy        User?         @relation("secretRequestCreator", fields: [requestedById], references: [id], onDelete: SetNull)
  /// Email auteur dénormalisé (subsiste après suppression de l'user).
  requestedByEmail   String
  /// Email destinataire optionnel — si rempli, envoi auto via Mailgun.
  recipientEmail     String?
  /// Org propriétaire de la demande (Cascade : delete org → delete requests).
  organizationId     String
  organization       Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Cible projet optionnelle (SetNull pour garder la trace même après
  /// suppression du projet — l'import devient impossible mais l'audit reste).
  projectId          String?
  project            Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  /// Nom de l'environnement cible (string, pas FK — l'env peut être renommé).
  environmentName    String?
  /// Clé .env cible (ex: "STRIPE_SECRET_KEY"). Validée à l'import contre /^[A-Z][A-Z0-9_]*$/.
  secretKey          String?
  /// Clé publique ECDH P-256 sérialisée JWK. Stockée à la création,
  /// jamais sensible (publique par essence).
  publicKeyJwk       String
  /// Clé publique ML-KEM-768 (base64), volet post-quantique de l'échange
  /// hybride. NULL pour les demandes legacy (ECDH seul). Publique par essence.
  mlkemPublicKey     String?
  /// Ciphertext base64 (AES-GCM). Vide tant que non soumis. Effacé après import/revoke.
  encryptedSecret    String?
  /// IV AES-GCM base64. Idem.
  secretIv           String?
  /// Clé publique éphémère du client (JWK). Idem — le serveur en a besoin
  /// pour donner à l'admin de quoi dériver la clé symétrique au moment du reveal.
  ephemeralPublicKey String?
  /// Ciphertext ML-KEM-768 (base64) produit par le tiers à la soumission.
  /// NULL pour les demandes legacy (ECDH seul).
  mlkemCiphertext    String?
  /// Version du format hybride : 1 = ECDH+ML-KEM, NULL = legacy ECDH seul.
  hybridVersion      Int?
  submittedAt        DateTime?
  /// IP du soumetteur (audit, abuse-tracking).
  submitterIp        String?
  /// TTL strict 48h depuis createdAt.
  expiresAt          DateTime
  viewedAt           DateTime?
  importedAt         DateTime?
  revokedAt          DateTime?
  createdAt          DateTime      @default(now())

  @@index([organizationId])
  @@index([projectId])
  @@index([expiresAt])
}

// ─── API Gateway ─────────────────────────────────────────────────────

enum ApiValidationMode {
  REMOTE
  JWT
}

model Api {
  id                     String            @id @default(cuid())
  projectId              String
  project                Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name                   String
  description            String?
  url                    String?
  mode                   ApiValidationMode @default(REMOTE)
  jwtSecret              String?
  jwtSecretIv            String?
  jwtSecretTag           String?
  defaultRateLimit       Int?
  defaultRateLimitWindow String            @default("1m")
  defaultExpiresIn       Int?
  liveEnvId              String?
  liveEnv                Environment?      @relation("apiLiveEnv", fields: [liveEnvId], references: [id], onDelete: SetNull)
  testEnvId              String?
  testEnv                Environment?      @relation("apiTestEnv", fields: [testEnvId], references: [id], onDelete: SetNull)
  keys                   ApiKey[]
  logs                   ApiLog[]
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@unique([projectId, name])
  @@index([projectId])
}

model ApiKey {
  id              String    @id @default(cuid())
  apiId           String
  api             Api       @relation(fields: [apiId], references: [id], onDelete: Cascade)
  keyHash         String    @unique
  keyPrefix       String
  name            String
  description     String?
  scopes          String[]
  rateLimit       Int?
  rateLimitWindow String?
  expiresAt       DateTime?
  lastUsedAt      DateTime?
  revokedAt       DateTime?
  createdById     String?
  createdBy       User?     @relation("apiKeyCreator", fields: [createdById], references: [id], onDelete: SetNull)
  meta            Json?
  createdAt       DateTime  @default(now())
  secrets         Secret[]  @relation("secretApiKey")

  @@index([apiId])
}

model ApiLog {
  id          String   @id @default(cuid())
  apiId       String
  api         Api      @relation(fields: [apiId], references: [id], onDelete: Cascade)
  keyId       String?
  keyPrefix   String?
  method      String
  path        String?
  ipAddress   String?
  userAgent   String?
  valid       Boolean
  reason      String?
  statusCode  Int?
  latencyMs   Int?
  createdAt   DateTime @default(now())

  @@index([apiId, createdAt(sort: Desc)])
  @@index([keyId, createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────────────────
// Modèles admin fusionnés en mono-DB pour le self-host.
//
// Dans secretvault (multi-tenant) ces modèles vivent dans le schéma `admin`
// (prisma/schema.prisma, denylisté). En self-host, base unique → on les
// append au schéma principal après le rename tenant-schema → schema.prisma.
// Append réalisé par build-public.mjs (cf. SCHEMA_APPEND_FILE).
//
// NB : `model Policy` n'est PAS ici — le tenant-schema le contient déjà
// (avec ses back-relations Project/Environment).
// ─────────────────────────────────────────────────────────────────────────

enum TokenKind {
  MACHINE
  PLUGIN
  SHARE
  SECRET_REQUEST
  USER
  ORG
}

model TokenIndex {
  tokenHash  String    @id @map("token_hash")
  tenantSlug String    @map("tenant_slug") @db.VarChar(100)
  kind       TokenKind
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([tenantSlug, kind])
}

model PasswordResetToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  tenantSlug String?   @map("tenant_slug") @db.VarChar(100)
  userId     String    @map("user_id")
  email      String    @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
}
