// Schéma "tenant" — pas de multiSchema, queries Prisma émises non-qualifiées
// (`SELECT * FROM "User"`) pour permettre le routing par `search_path` en
// Phase 3 (schema-per-tenant `client_<slug>`).
//
// Ce fichier est une COPIE des modèles tenant de prisma/schema.prisma sans
// les annotations @@schema. Il ne sert QU'à la codegen du client tenant
// (utilisé par défaut dans lib/prisma.ts → `import { prisma }`).
//
// Source de vérité pour les migrations DB : prisma/schema.prisma. Quand
// un modèle tenant change, mettre à jour les DEUX fichiers en parallèle.
// Les modèles admin (Client, Subscription, AuditLog) ne sont PAS dans ce
// fichier — ils restent dans prisma/schema.prisma + multiSchema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String            @id @default(cuid())
  email                String            @unique
  password             String
  role                 Role              @default(MEMBER)
  /// 2FA TOTP — secret chiffré avec la même ENCRYPTION_KEY que les Secrets
  /// (3 colonnes : encryptedValue/iv/tag, base64). Désactivé par défaut.
  twoFactorEnabled     Boolean           @default(false)
  twoFactorSecret      String?
  twoFactorIv          String?
  twoFactorTag         String?
  /// 8 codes de secours bcrypt-hashés. Vidé à chaque rotation 2FA.
  backupCodes          String[]          @default([])
  projects             ProjectMember[]
  organizations        OrgMember[]
  invitationsSent      Invitation[]      @relation("invitedBy")
  invitationsReceived  Invitation[]      @relation("invitationsReceived")
  createdMachineTokens MachineToken[]    @relation("machineTokenCreator")
  pluginTokens         PluginToken[]
  vaultEntries         VaultEntry[]
  vaultCollections     VaultCollection[]
  teamVaultMemberships TeamVaultMember[]
  oneTimeShares        OneTimeShare[]    @relation("oneTimeShareCreator")
  accessLogs           AccessLog[]       @relation("accessLogActor")
  secretRequests       SecretRequest[]   @relation("secretRequestCreator")
  secretVersions       SecretVersion[]   @relation("secretVersionCreator")
  orgSecretVersions    OrgSecretVersion[] @relation("orgSecretVersionCreator")
  userTokens           UserToken[]
  orgTokensCreated     OrgToken[]        @relation("orgTokenCreator")
  createdAt            DateTime          @default(now())
}

model PluginToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?
  userAgent  String?

  @@index([userId])
  @@index([expiresAt])
}

model Organization {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String                @unique
  members              OrgMember[]
  projects             Project[]
  invitations          Invitation[]
  secrets              OrgSecret[]
  servers              Server[]
  teamVaultCollections TeamVaultCollection[]
  oneTimeShares        OneTimeShare[]
  accessLogs           AccessLog[]
  secretRequests       SecretRequest[]
  orgTokens            OrgToken[]
  createdAt            DateTime              @default(now())
}

model Server {
  id             String        @id @default(cuid())
  name           String
  ip             String
  sshUser        String
  encryptedKey   String
  iv             String
  tag            String
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  environments   Environment[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model OrgSecret {
  id             String             @id @default(cuid())
  key            String
  encryptedValue String
  iv             String
  tag            String
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions       OrgSecretVersion[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([organizationId, key])
}

model OrgMember {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           OrgRole      @default(MEMBER)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
}

model Invitation {
  id             String    @id @default(cuid())
  email          String
  organizationId String
  role           OrgRole   @default(MEMBER)
  tokenHash      String    @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  invitedById    String
  inviteeUserId  String?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("invitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  inviteeUser  User?        @relation("invitationsReceived", fields: [inviteeUserId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([inviteeUserId])
}

model Project {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String                @unique
  organizationId       String
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members              ProjectMember[]
  environments         Environment[]
  tokens               MachineToken[]
  accessLogs           AccessLog[]
  services             Service[]
  appAccounts          AppAccount[]
  policies             Policy[]
  teamVaultCollections TeamVaultCollection[]
  secretRequests       SecretRequest[]
  githubRepo           String?
  githubWorkflow       String?
  createdAt            DateTime              @default(now())

  @@index([organizationId])
}

model Policy {
  id            String      @id @default(cuid())
  repo          String
  workflow      String
  branch        String
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([repo, workflow, branch, projectId, environmentId])
  @@index([repo, workflow, branch])
  @@index([projectId])
  @@index([environmentId])
}

model Service {
  id            String   @id @default(cuid())
  name          String
  url           String?
  encryptedData String
  iv            String
  tag           String
  /// Tags techniques pour filtrage par les intégrations (N8n, Make).
  tags          String[] @default([])
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
}

model AppAccount {
  id            String   @id @default(cuid())
  name          String
  encryptedData String
  iv            String
  tag           String
  /// Tags techniques pour filtrage par les intégrations (N8n, Make).
  tags          String[] @default([])
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
}

model Environment {
  id            String         @id @default(cuid())
  name          String
  projectId     String
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url           String?
  dockerCompose String?
  serverId      String?
  server        Server?        @relation(fields: [serverId], references: [id], onDelete: SetNull)
  deployPath    String?
  secrets       Secret[]
  tokens        MachineToken[]
  policies      Policy[]

  @@unique([projectId, name])
  @@index([serverId])
}

model Secret {
  id             String          @id @default(cuid())
  key            String
  encryptedValue String
  iv             String
  tag            String
  category       String?
  /// Tags techniques pour filtrage par les intégrations (N8n, Make).
  tags           String[]        @default([])
  environmentId  String
  environment    Environment     @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  versions       SecretVersion[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([environmentId, key])
}

/// Historique des valeurs d'un Secret (Phase 10 — versioning).
/// Rétention 50 max par secret, UNIQUE(secretId, version) pour gérer les
/// race conditions sur MAX(version)+1 (retry côté code).
model SecretVersion {
  id             String   @id @default(cuid())
  secretId       String
  secret         Secret   @relation(fields: [secretId], references: [id], onDelete: Cascade)
  encryptedValue String
  iv             String
  tag            String
  version        Int
  createdById    String?
  createdBy      User?    @relation("secretVersionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@unique([secretId, version])
  @@index([secretId, version(sort: Desc)])
}

/// Historique des valeurs d'un OrgSecret (Phase 10 — versioning).
model OrgSecretVersion {
  id             String    @id @default(cuid())
  orgSecretId    String
  orgSecret      OrgSecret @relation(fields: [orgSecretId], references: [id], onDelete: Cascade)
  encryptedValue String
  iv             String
  tag            String
  version        Int
  createdById    String?
  createdBy      User?     @relation("orgSecretVersionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now())

  @@unique([orgSecretId, version])
  @@index([orgSecretId, version(sort: Desc)])
}

model MachineToken {
  id            String      @id @default(cuid())
  name          String
  tokenHash     String      @unique
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  createdById   String?
  createdBy     User?       @relation("machineTokenCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lastUsedAt    DateTime?
  createdAt     DateTime    @default(now())
  revokedAt     DateTime?
}

/// UserToken (Phase 11a) — token Bearer scopé à un User. Donne accès READ
/// aux projets dont l'user est ProjectMember. Préfixe brut `sv_user_<32 hex>`.
model UserToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  tokenHash  String    @unique
  prefix     String
  expiresAt  DateTime?
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// OrgToken (Phase 11c) — token Bearer scopé à une Organization. Survit
/// au départ du créateur (createdById SetNull). Workflows N8n / Make
/// pérennes. Préfixe brut `sv_org_<32 hex>`.
model OrgToken {
  id                String          @id @default(cuid())
  organizationId    String
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  tokenHash         String          @unique
  prefix            String
  allProjects       Boolean         @default(false)
  allowedProjectIds String[]        @default([])
  allowedScopes     OrgTokenScope[] @default([])
  expiresAt         DateTime?
  lastUsedAt        DateTime?
  revokedAt         DateTime?
  createdById       String?
  createdBy         User?           @relation("orgTokenCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt         DateTime        @default(now())

  @@index([organizationId])
  @@index([expiresAt])
}

enum OrgTokenScope {
  SECRETS_READ
  SERVICES_READ
  ACCOUNTS_READ
  PROJECTS_LIST
}

model ProjectMember {
  id        String      @id @default(cuid())
  userId    String
  projectId String
  role      ProjectRole @default(VIEWER)
  hidden    Boolean     @default(false)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

enum Role {
  ADMIN
  MEMBER
  SUPERADMIN
}

enum OrgRole {
  OWNER
  ADMIN
  DEV
  MEMBER
}

enum ProjectRole {
  OWNER
  EDITOR
  VIEWER
}

model VaultEntry {
  id                  String           @id @default(cuid())
  userId              String
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Collection perso optionnelle (V2.0). NULL = "Sans catégorie".
  collectionId        String?
  collection          VaultCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  name                String
  url                 String?
  username            String?
  encryptedPassword   String?
  passwordIv          String?
  passwordTag         String?
  encryptedTotpSecret String?
  totpSecretIv        String?
  totpSecretTag       String?
  tags                String[]         @default([])
  favorite            Boolean          @default(false)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([userId])
  @@index([collectionId])
}

/// Collection perso d'un User (V2.0 — coffre personnel).
/// Mirror simplifié de TeamVaultCollection : pas de members, scope user
/// strict (un user n'accède qu'à SES collections).
model VaultCollection {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  entries   VaultEntry[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([userId, slug])
  @@index([userId])
}

model TeamVaultCollection {
  id             String            @id @default(cuid())
  organizationId String?
  organization   Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  entries        TeamVaultEntry[]
  members        TeamVaultMember[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([organizationId, slug])
  @@unique([projectId, slug])
  @@index([organizationId])
  @@index([projectId])
}

model TeamVaultEntry {
  id                  String              @id @default(cuid())
  collectionId        String
  collection          TeamVaultCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  name                String
  url                 String?
  username            String?
  encryptedPassword   String?
  passwordIv          String?
  passwordTag         String?
  encryptedTotpSecret String?
  totpSecretIv        String?
  totpSecretTag       String?
  tags                String[]            @default([])
  favorite            Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([collectionId])
}

model TeamVaultMember {
  id           String              @id @default(cuid())
  collectionId String
  userId       String
  role         VaultRole           @default(VIEWER)
  collection   TeamVaultCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime            @default(now())

  @@unique([collectionId, userId])
}

enum VaultRole {
  OWNER
  EDITOR
  VIEWER
}

model AccessLog {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  environmentId  String?
  actorUserId    String?
  actorUser      User?         @relation("accessLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorUserEmail String?
  actorTokenId   String?
  actorTokenName String?
  action         AccessAction
  targetType     String?
  targetId       String?
  secretKey      String?
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime      @default(now())

  @@index([organizationId, createdAt])
  @@index([projectId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model OneTimeShare {
  id               String        @id @default(cuid())
  tokenHash        String        @unique
  ciphertext       String
  iv               String
  title            String?
  passwordHash     String?
  passwordAttempts Int           @default(0)
  createdById      String
  createdBy        User          @relation("oneTimeShareCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdByEmail   String
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  expiresAt        DateTime
  consumedAt       DateTime?
  viewedFromIp     String?
  revokedAt        DateTime?
  createdAt        DateTime      @default(now())

  @@index([createdById])
  @@index([expiresAt])
}

