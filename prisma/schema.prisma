// Schéma "tenant" — pas de multiSchema, queries Prisma émises non-qualifiées
// (`SELECT * FROM "User"`) pour permettre le routing par `search_path` en
// Phase 3 (schema-per-tenant `client_<slug>`).
//
// Ce fichier est une COPIE des modèles tenant de prisma/schema.prisma sans
// les annotations @@schema. Il ne sert QU'à la codegen du client tenant
// (utilisé par défaut dans lib/prisma.ts → `import { prisma }`).
//
// Source de vérité pour les migrations DB : prisma/schema.prisma. Quand
// un modèle tenant change, mettre à jour les DEUX fichiers en parallèle.
// Les modèles admin (Client, Subscription, AuditLog) ne sont PAS dans ce
// fichier — ils restent dans prisma/schema.prisma + multiSchema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String            @id @default(cuid())
  email                String            @unique
  password             String
  role                 Role              @default(MEMBER)
  /// 2FA TOTP — secret chiffré avec la même ENCRYPTION_KEY que les Secrets
  /// (3 colonnes : encryptedValue/iv/tag, base64). Désactivé par défaut.
  twoFactorEnabled     Boolean           @default(false)
  twoFactorSecret      String?
  twoFactorIv          String?
  twoFactorTag         String?
  /// 8 codes de secours bcrypt-hashés. Vidé à chaque rotation 2FA.
  backupCodes          String[]          @default([])
  projects             ProjectMember[]
  organizations        OrgMember[]
  invitationsSent      Invitation[]      @relation("invitedBy")
  invitationsReceived  Invitation[]      @relation("invitationsReceived")
  createdMachineTokens MachineToken[]    @relation("machineTokenCreator")
  pluginTokens         PluginToken[]
  vaultEntries         VaultEntry[]
  vaultCollections     VaultCollection[]
  teamVaultMemberships TeamVaultMember[]
  userTokens           UserToken[]
  orgTokensCreated     OrgToken[]        @relation("orgTokenCreator")
  oneTimeShares        OneTimeShare[]    @relation("oneTimeShareCreator")
  accessLogs           AccessLog[]       @relation("accessLogActor")
  secretRequests       SecretRequest[]   @relation("secretRequestCreator")
  secretVersions       SecretVersion[]   @relation("secretVersionCreator")
  orgSecretVersions    OrgSecretVersion[] @relation("orgSecretVersionCreator")
  apiKeysCreated       ApiKey[]          @relation("apiKeyCreator")
  createdAt            DateTime          @default(now())
  /// #5 — borne basse de validité des sessions : tout JWT émis avant cette
  /// date est rejeté par requireUser(). Posé au reset password / 2FA disable
  /// pour couper les sessions existantes. NULL = jamais invalidé (legacy).
  sessionsValidFrom    DateTime?
}

model PluginToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?
  userAgent  String?

  @@index([userId])
  @@index([expiresAt])
}

model Organization {
  id                     String                @id @default(cuid())
  name                   String
  slug                   String                @unique
  members                OrgMember[]
  projects               Project[]
  invitations            Invitation[]
  secrets                OrgSecret[]
  servers                Server[]
  teamVaultCollections   TeamVaultCollection[]
  oneTimeShares          OneTimeShare[]
  accessLogs             AccessLog[]
  secretRequests         SecretRequest[]
  orgTokens              OrgToken[]
  rotationFeatureEnabled Boolean               @default(false)
  // ─── Cloisonnement orgs (refonte pricing) ──────────────────────────
  /// org principale = compte général du tenant. Ses quotas sont DÉRIVÉS
  /// du plan (PLAN_QUOTAS + client.extra*) ; les champs maxX ci-dessous
  /// sont ignorés pour la primaire. Les orgs ajoutées portent leur
  /// propre bundle isolé (ADDON_ORG_BUNDLE).
  isPrimary              Boolean               @default(false)
  /// Quotas isolés des orgs AJOUTÉES (defaults = ADDON_ORG_BUNDLE).
  maxServers             Int                   @default(2)
  maxOidcProjects        Int                   @default(10)
  /// Posé pour le futur — emails restent métrés au niveau client (non
  /// branché par org en Phase B).
  maxEmailsPerMonth      Int                   @default(1000)
  extraEmails            Int                   @default(0)
  /// Sièges propres à l'org (confinés, isolés du pool global du plan).
  maxSeats               Int                   @default(2)
  createdAt              DateTime              @default(now())
}

/// Configuration email Pink-Floyd au niveau CLIENT (tenant) — singleton par
/// schéma tenant. Le compte Pink-Floyd est créé avec `externalRef = tenantSlug`
/// (globalement unique, contrairement au slug d'org qui ne l'est qu'au sein du
/// tenant). `accountId` = compte partagé par TOUS les projets/orgs du client.
/// `enabled` : interrupteur explicite. `tenantSlug` sert de clé d'upsert.
model ClientEmailConfig {
  id         String   @id @default(cuid())
  tenantSlug String   @unique
  enabled    Boolean  @default(false)
  accountId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Interrupteur du service de backup automatisé au niveau CLIENT (tenant) —
/// singleton par schéma tenant, comme ClientEmailConfig. `enabled` = master
/// switch ; la config par projet (ProjectBackupConfig, cf. spec backups-auto.md)
/// viendra ensuite et exigera ce switch.
model ClientBackupConfig {
  id         String   @id @default(cuid())
  tenantSlug String   @unique
  enabled    Boolean  @default(false)
  /// Destination des backups, au niveau CLIENT (un VPS pour tous ses projets).
  /// Le chemin effectif d'un projet est dérivé : backupPath/<slug projet>.
  backupServerId String?
  backupServer   Server? @relation("BackupDest", fields: [backupServerId], references: [id])
  backupPath     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Config de backup automatisé d'un projet (cf. docs/steps-docs/backups-auto.md).
/// Physalis ne détient QUE la clé GPG publique (postée par l'agent) ; ni le mot
/// de passe DB ni la clé privée ne vivent ici. La destination est un Server.
model ProjectBackupConfig {
  id               String   @id @default(cuid())
  projectId        String   @unique
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  enabled          Boolean  @default(false)
  /// Un seul environnement backupé par projet (prod par défaut).
  environmentName  String

  // DB(s) source : multi-DB → modèle enfant ProjectBackupDatabase.
  // La destination vit au niveau CLIENT (ClientBackupConfig).

  // GPG : Physalis ne tient que le public (posté par l'agent à l'enregistrement)
  gpgPublicKey      String?
  gpgKeyId          String?
  agentRegisteredAt DateTime?
  /// Hash SHA-256 du token d'agent — vérifie register/plan/report (timingSafeEqual,
  /// sans déchiffrer à chaque poll).
  agentTokenHash    String?
  /// Copie chiffrée (AES-256-GCM) du MÊME token, pour l'injection zéro-touch dans le
  /// bundle de déploiement (Physalis déchiffre et pose BACKUP_TOKEN). Même posture que
  /// la clé SSH du serveur, déjà dans le bundle. Null tant qu'aucun token n'a été émis.
  agentTokenEnc     String?
  agentTokenIv      String?
  agentTokenTag     String?
  /// Anti-spam du watchdog : dernière alerte « backup en retard » envoyée.
  overdueAlertedAt  DateTime?

  // Rétention (appliquée côté agent)
  retentionDaily   Int      @default(7)
  retentionWeekly  Int      @default(4)
  retentionMonthly Int      @default(3)

  // Planification (servie à l'agent ; le cron Physalis = watchdog)
  scheduleHour     Int      @default(3)
  intervalDays     Int      @default(1)
  backupNextAt     DateTime?
  backupLastAt     DateTime?
  backupLastStatus String?
  backupErrorCount Int      @default(0)
  forceRequestedAt DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  databases        ProjectBackupDatabase[]
  entries          ProjectBackupEntry[]
}

/// Une DB d'un projet à sauvegarder (un projet peut en avoir plusieurs).
/// Détectée depuis le docker-compose + .env, éditable par l'utilisateur.
/// Physalis ne stocke PAS le mot de passe : seulement la clé du secret (.env)
/// qui le contient, pour l'injecter au déploiement.
model ProjectBackupDatabase {
  id                String              @id @default(cuid())
  configId          String
  config            ProjectBackupConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  dbType            BackupDbType
  dbName            String
  /// Hostname sur le réseau docker du projet (= nom du service db).
  dbHost            String
  dbUser            String
  /// Clé du secret (.env) contenant le mot de passe (null si en clair / non résolu).
  passwordSecretKey String?
  port              Int?
  enabled           Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([configId])
}

/// Une archive de backup (remplie par les rapports de l'agent — tranche suivante).
model ProjectBackupEntry {
  id              String              @id @default(cuid())
  projectId       String
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  configId        String
  config          ProjectBackupConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  filename        String
  sizeBytes       BigInt?
  dbType          BackupDbType
  dbName          String
  environmentName String
  destLocation    String

  status          BackupEntryStatus
  errorMessage    String?
  restorable      Boolean  @default(true)
  restoreJobId    String?
  createdAt       DateTime @default(now())

  @@index([projectId, createdAt(sort: Desc)])
  @@index([projectId, status])
  @@index([configId])
}

enum BackupDbType {
  POSTGRESQL
  MYSQL
  MARIADB
}

enum BackupEntryStatus {
  PENDING
  SUCCESS
  FAILED
}

/// Configuration email Pink-Floyd au niveau projet : un domaine + une clé API
/// par projet, partagés par tous ses environnements (injectés dans le .env au
/// déploiement). La clé API est chiffrée au repos (même schéma AES-256-GCM que
/// Secret/Service). Les enregistrements DNS sont mémorisés en JSON.
model ProjectEmailConfig {
  id           String   @id @default(cuid())
  projectId    String   @unique
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  domain       String
  domainId     String
  keyId        String
  encryptedKey String
  iv           String
  tag          String
  verified     Boolean  @default(false)
  dnsRecords   Json     @default("[]")
  /// Rotation automatique de la clé API (blue/green). À la rotation, on crée
  /// une nouvelle clé + redeploy, et on diffère la révocation de l'ancienne au
  /// cycle suivant (fenêtre de grâce — l'app lit la clé depuis son .env, mis à
  /// jour seulement au redeploy). `pendingRevokeKeyId` = ancienne clé à révoquer.
  rotationEnabled     Boolean   @default(false)
  rotationIntervalDays Int?
  rotationNextAt      DateTime?
  rotationLastAt      DateTime?
  rotationLastStatus  String?
  rotationErrorCount  Int       @default(0)
  pendingRevokeKeyId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([rotationNextAt])
}

model Server {
  id             String        @id @default(cuid())
  name           String
  ip             String
  sshUser        String
  encryptedKey   String
  iv             String
  tag            String
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  environments   Environment[]
  backupDests    ClientBackupConfig[] @relation("BackupDest")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

enum DatabaseType {
  POSTGRESQL
  MYSQL
  MONGODB
}

model OrgSecret {
  id             String             @id @default(cuid())
  key            String
  encryptedValue String
  iv             String
  tag            String
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions       OrgSecretVersion[]
  /// Rappel manuel de renouvellement (ex. expiration d'un PAT). Saisi à la création
  /// via une durée ; Physalis ne connaît pas l'expiration réelle d'un token GitHub.
  expiresAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([organizationId, key])
}

/// Historique des valeurs d'un OrgSecret (Phase 10 — versioning).
/// Cf. SecretVersion pour la spec complète. Mêmes contraintes :
/// rétention 50 versions, UNIQUE(orgSecretId, version) pour les races.
model OrgSecretVersion {
  id             String    @id @default(cuid())
  orgSecretId    String
  orgSecret      OrgSecret @relation(fields: [orgSecretId], references: [id], onDelete: Cascade)
  encryptedValue String
  iv             String
  tag            String
  version        Int
  createdById    String?
  createdBy      User?     @relation("orgSecretVersionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now())

  @@unique([orgSecretId, version])
  @@index([orgSecretId, version(sort: Desc)])
}

model OrgMember {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           OrgRole      @default(MEMBER)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
}

model Invitation {
  id             String    @id @default(cuid())
  email          String
  organizationId String
  role           OrgRole   @default(MEMBER)
  tokenHash      String    @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  invitedById    String
  inviteeUserId  String?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("invitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  inviteeUser  User?        @relation("invitationsReceived", fields: [inviteeUserId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([inviteeUserId])
}

model Project {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String                @unique
  organizationId       String
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members              ProjectMember[]
  environments         Environment[]
  tokens               MachineToken[]
  accessLogs           AccessLog[]
  services             Service[]
  appAccounts          AppAccount[]
  policies             Policy[]
  teamVaultCollections TeamVaultCollection[]
  secretRequests       SecretRequest[]
  apis                 Api[]
  emailConfig          ProjectEmailConfig?
  backupConfig         ProjectBackupConfig?
  backupEntries        ProjectBackupEntry[]
  docs                 ProjectDoc[]
  githubRepo           String?
  githubWorkflow       String?
  /// Dernier fetch des docs depuis le repo (null = jamais tenté). Distingue
  /// « aucun fichier de doc » de « jamais récupéré ».
  docsFetchedAt        DateTime?
  rotationPaused       Boolean               @default(false)
  createdAt            DateTime              @default(now())

  @@index([organizationId])
}

/// Doc projet récupérée depuis le repo GitHub (readme / technique / sécurité) et
/// mise en cache. Une ligne n'existe QUE si le fichier existait au dernier fetch
/// → l'absence de ligne = fichier absent. Cf. physalis.md.
model ProjectDoc {
  id        String         @id @default(cuid())
  projectId String
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kind      ProjectDocKind
  content   String         // markdown brut
  fetchedAt DateTime       @default(now())

  @@unique([projectId, kind])
  @@index([projectId])
}

enum ProjectDocKind {
  README
  TECHNICAL
  SECURITY
}

model Policy {
  id            String      @id @default(cuid())
  repo          String
  workflow      String
  branch        String
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([repo, workflow, branch, projectId, environmentId])
  @@index([repo, workflow, branch])
  @@index([projectId])
  @@index([environmentId])
}

model Service {
  id            String   @id @default(cuid())
  name          String
  url           String?
  encryptedData String
  iv            String
  tag           String
  /// Tags techniques pour le filtrage dans les intégrations (N8n/Make).
  /// Distinct de `Secret.category` (organisation visuelle UI). Ex: ["stripe", "production"].
  tags          String[] @default([])
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
}

model AppAccount {
  id            String   @id @default(cuid())
  name          String
  encryptedData String
  iv            String
  tag           String
  /// Tags techniques pour le filtrage dans les intégrations (N8n/Make).
  tags          String[] @default([])
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
}

model Environment {
  id            String         @id @default(cuid())
  name          String
  projectId     String
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url           String?
  dockerCompose String?
  serverId      String?
  server        Server?        @relation(fields: [serverId], references: [id], onDelete: SetNull)
  deployPath    String?
  secrets       Secret[]
  tokens        MachineToken[]
  policies      Policy[]
  liveApis      Api[]          @relation("apiLiveEnv")
  testApis      Api[]          @relation("apiTestEnv")

  @@unique([projectId, name])
  @@index([serverId])
}

model Secret {
  id                    String            @id @default(cuid())
  key                   String
  encryptedValue        String
  iv                    String
  tag                   String
  category              String?
  /// Tags techniques pour le filtrage dans les intégrations (N8n/Make).
  /// Distinct de `category` (organisation visuelle UI). Ex: ["postgres", "production"].
  tags                  String[]          @default([])
  environmentId         String
  environment           Environment       @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  versions              SecretVersion[]
  rotationEnabled       Boolean           @default(false)
  rotationStrategy      RotationStrategy?
  rotationIntervalDays  Int?
  rotationLastAt        DateTime?
  rotationNextAt        DateTime?
  rotationLastStatus    String?           // "success" | "error" | null
  rotationErrorCount    Int               @default(0)
  dbHost                String?
  dbPort                Int?
  dbName                String?
  dbType                DatabaseType?
  dbUser                String?
  rotationNeedsFullDeploy Boolean          @default(false)
  rotationWebhookUrl    String?
  jwtRedeployWebhookUrl String?
  apiKeyId              String?
  apiKey                ApiKey?           @relation("secretApiKey", fields: [apiKeyId], references: [id], onDelete: SetNull)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@unique([environmentId, key])
  @@index([rotationNextAt])
}

enum RotationStrategy {
  DATABASE
  JWT_SECRET
  WEBHOOK
  REMINDER
  API_KEY
}

/// Historique des valeurs d'un Secret (Phase 10 — versioning).
/// Chaque row = un snapshot de l'ancienne valeur juste avant un update.
/// Rétention : 50 versions max par secret (cleanup au INSERT côté code).
/// UNIQUE(secretId, version) pour gérer les race conditions sur
/// MAX(version)+1 — retry côté code en cas de conflit.
model SecretVersion {
  id             String   @id @default(cuid())
  secretId       String
  secret         Secret   @relation(fields: [secretId], references: [id], onDelete: Cascade)
  encryptedValue String
  iv             String
  tag            String
  version        Int
  createdById    String?
  createdBy      User?    @relation("secretVersionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@unique([secretId, version])
  @@index([secretId, version(sort: Desc)])
}

model MachineToken {
  id            String      @id @default(cuid())
  name          String
  tokenHash     String      @unique
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environmentId String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  createdById   String?
  createdBy     User?       @relation("machineTokenCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lastUsedAt    DateTime?
  createdAt     DateTime    @default(now())
  revokedAt     DateTime?
}

/// UserToken (Phase 11a) — token Bearer scopé à un User (vs MachineToken
/// scopé project+env). Donne accès READ aux projets dont l'user est
/// ProjectMember, à son rôle effectif (VIEWER+). Cas d'usage : workflow
/// N8n / Make / scripts qui touchent plusieurs projets sous le même
/// compte. Préfixe brut `sv_user_<32 hex>` distinguable de `sv_<hex>`.
model UserToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Libellé libre choisi par l'user, ex: "N8n Voyages workflows".
  name       String
  /// SHA-256 du token brut. UNIQUE pour le lookup au runtime.
  tokenHash  String    @unique
  /// 12 premiers chars du token (`sv_user_xxxx`) — affichage UI sans
  /// exposer le secret après la création.
  prefix     String
  /// Optionnel — null = jamais.
  expiresAt  DateTime?
  lastUsedAt DateTime?
  /// Révocation soft (revokedAt = now()) — évite le hard DELETE pour
  /// préserver les liens `INTEGRATION_*_FETCH` dans les AccessLog.
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// OrgToken (Phase 11c) — token Bearer scopé à une Organization. Survit
/// au départ du user créateur (createdById SetNull, pas Cascade) — c'est
/// le différenciateur principal vs UserToken. Cas d'usage : workflows
/// N8n / Make institutionnels pérennes.
///
/// Permissions explicites :
///   - allowedScopes : enum OrgTokenScope (READ uniquement en V1)
///   - allowedProjectIds : tableau d'IDs de projets autorisés
///   - allProjects : boolean — true ouvre l'accès à tous les projets
///                   actuels et FUTURS de l'org
///
/// Sémantique :
///   - allProjects=false ET allowedProjectIds=[]   → AUCUN accès (état
///     invalide, à éviter via UI qui force la sélection)
///   - allProjects=false ET allowedProjectIds=[..] → seulement ces projets
///   - allProjects=true                            → tous les projets
///                                                   (allowedProjectIds ignoré)
///
/// Préfixe brut : `sv_org_<32 hex>`. OrgSecrets (lus via le panel
/// `/orgs/[slug]/secrets`) ne sont JAMAIS accessibles via OrgToken par
/// design — pas de scope dédié.
model OrgToken {
  id                String          @id @default(cuid())
  organizationId    String
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  tokenHash         String          @unique
  /// 12 premiers chars du token (`sv_org_xxxx`) pour affichage UI.
  prefix            String
  /// true → accès à tous les projets actuels ET FUTURS de l'org.
  /// Marker explicite (vs tableau vide ambigu) — vide = aucun accès.
  allProjects       Boolean         @default(false)
  allowedProjectIds String[]        @default([])
  allowedScopes     OrgTokenScope[] @default([])
  expiresAt         DateTime?
  lastUsedAt        DateTime?
  revokedAt         DateTime?
  /// SetNull au DELETE user → le token survit (différenciateur vs UserToken).
  createdById       String?
  createdBy         User?           @relation("orgTokenCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt         DateTime        @default(now())

  @@index([organizationId])
  @@index([expiresAt])
}

enum OrgTokenScope {
  SECRETS_READ
  SERVICES_READ
  ACCOUNTS_READ
  PROJECTS_LIST
}

model ProjectMember {
  id        String      @id @default(cuid())
  userId    String
  projectId String
  role      ProjectRole @default(VIEWER)
  hidden    Boolean     @default(false)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

enum Role {
  ADMIN
  MEMBER
  SUPERADMIN
}

enum OrgRole {
  OWNER
  ADMIN
  ADMIN_DEV
  DEV
  MEMBER
}

enum ProjectRole {
  OWNER
  EDITOR
  VIEWER
}

model VaultEntry {
  id                  String           @id @default(cuid())
  userId              String
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Collection perso optionnelle (V2.0). NULL = "Sans catégorie".
  /// SetNull on delete : supprimer une collection ne supprime pas ses entrées.
  collectionId        String?
  collection          VaultCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  name                String
  url                 String?
  username            String?
  encryptedPassword   String?
  passwordIv          String?
  passwordTag         String?
  encryptedTotpSecret String?
  totpSecretIv        String?
  totpSecretTag       String?
  /// Score de force du mot de passe (0-4, heuristique à la zxcvbn), calculé
  /// côté serveur au save. NULL = pas de mot de passe.
  passwordStrength    Int?
  tags                String[]         @default([])
  favorite            Boolean          @default(false)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([userId])
  @@index([collectionId])
}

/// Collection perso d'un User (V2.0 — coffre personnel).
/// Mirror simplifié de TeamVaultCollection : pas de members, scope user
/// strict (un user n'accède qu'à SES collections). Déclenchant `slug`
/// unique par user pour permettre des URLs propres + import idempotent.
model VaultCollection {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  entries   VaultEntry[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([userId, slug])
  @@index([userId])
}

model TeamVaultCollection {
  id             String            @id @default(cuid())
  organizationId String?
  organization   Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  entries        TeamVaultEntry[]
  members        TeamVaultMember[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([organizationId, slug])
  @@unique([projectId, slug])
  @@index([organizationId])
  @@index([projectId])
}

model TeamVaultEntry {
  id                  String              @id @default(cuid())
  collectionId        String
  collection          TeamVaultCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  name                String
  url                 String?
  username            String?
  encryptedPassword   String?
  passwordIv          String?
  passwordTag         String?
  encryptedTotpSecret String?
  totpSecretIv        String?
  totpSecretTag       String?
  tags                String[]            @default([])
  favorite            Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([collectionId])
}

model TeamVaultMember {
  id           String              @id @default(cuid())
  collectionId String
  userId       String
  role         VaultRole           @default(VIEWER)
  collection   TeamVaultCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime            @default(now())

  @@unique([collectionId, userId])
}

enum VaultRole {
  OWNER
  EDITOR
  VIEWER
}

model AccessLog {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  environmentId  String?
  actorUserId    String?
  actorUser      User?         @relation("accessLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorUserEmail String?
  actorTokenId   String?
  actorTokenName String?
  action         AccessAction
  targetType     String?
  targetId       String?
  secretKey      String?
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime      @default(now())

  @@index([organizationId, createdAt])
  @@index([projectId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model OneTimeShare {
  id               String        @id @default(cuid())
  tokenHash        String        @unique
  ciphertext       String
  iv               String
  title            String?
  passwordHash     String?
  passwordAttempts Int           @default(0)
  createdById      String
  createdBy        User          @relation("oneTimeShareCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdByEmail   String
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  expiresAt        DateTime
  consumedAt       DateTime?
  viewedFromIp     String?
  revokedAt        DateTime?
  createdAt        DateTime      @default(now())

  @@index([createdById])
  @@index([expiresAt])
}

