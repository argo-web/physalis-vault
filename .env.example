# =============================================================================
# Physalis — Configuration
# Copier ce fichier en .env et renseigner les valeurs manquantes.
# =============================================================================

# --- Base de données ---
# Mot de passe Postgres. Choisi librement, doit être identique partout.
DB_PASSWORD="changeme"

# --- Chiffrement ---
# Clé AES-256 — générer avec : openssl rand -hex 32
# ⚠️  Ne jamais perdre cette clé : les secrets ne sont pas récupérables sans elle.
ENCRYPTION_KEY=""

# --- Authentification ---
# Générer avec : openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_SECRET=""

# URL publique de l'instance (sans slash final).
# En local : http://localhost:3000
# En production : https://vault.exemple.fr
NEXTAUTH_URL="http://localhost:3000"

# --- Premier compte admin ---
# Créé automatiquement au premier démarrage ; ignoré si le compte existe déjà.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD=""   # minimum 12 caractères

# --- Inscription publique ---
# "true" pour autoriser tout le monde à créer un compte.
ALLOW_REGISTRATION="false"

# --- Port hôte (optionnel) ---
# Port exposé sur la machine hôte. Par défaut 3000.
# Le conteneur tourne toujours sur 3000 en interne — seul le port hôte change.
# PORT=3000

# --- Email (invitations, reset password) ---
# Laisser vide pour désactiver les emails (non bloquant au démarrage).
# EMAIL_MAILGUN_API_KEY=
# EMAIL_MAILGUN_DOMAIN=
# EMAIL_MAILGUN_HOST=api.eu.mailgun.net
# EMAIL_FROM=Physalis <noreply@exemple.fr>

# --- OIDC GitHub Actions (optionnel) ---
# Requis uniquement si vous utilisez /api/deploy dans vos workflows GitHub.
# Valeur recommandée : hostname public du vault (ex. vault.exemple.fr).
# OIDC_AUDIENCE=vault.exemple.fr

# --- Extension navigateur (optionnel) ---
# Format : chrome-extension://<id> ou moz-extension://<id>
# Si absent, tous les endpoints /api/plugin/* répondent 403.
# PLUGIN_ALLOWED_ORIGIN=chrome-extension://xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
