# --- Base de donnees ---
# DEV (avec docker-compose.dev.yml) : la DB est exposee sur localhost:5434
# (5432/5433 sont souvent deja pris par un Postgres natif sur l'hote)
DATABASE_URL="postgresql://physalis:physalis_dev@localhost:5434/physalis"

# Mot de passe utilise par les conteneurs Postgres (dev et prod)
DB_PASSWORD="physalis_dev"

# --- Chiffrement ---
# AES-256 — generer avec : openssl rand -hex 32
ENCRYPTION_KEY=""

# --- NextAuth ---
# Generer avec : openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3001"

# --- Premier compte admin (utilise au premier demarrage seulement) ---
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD=""

# --- Inscription publique desactivee par defaut ---
ALLOW_REGISTRATION="false"

# --- Notes prod ---
# En production (docker-compose.yml), DATABASE_URL est surcharge par
# docker-compose pour pointer vers le service "db" du reseau interne.
# Le reseau "nginx_default" doit exister (cree par Nginx Proxy Manager).
#
# Image GHCR utilisee par docker-compose.prod.yml (overlay) :
#   IMAGE=ghcr.io/<owner>/<repo>:latest
# Doit matcher exactement le tag pousse par le workflow GitHub Actions.

# --- Email (invitations) ---
# Mailgun (decommenter et completer pour activer) :
# EMAIL_MAILGUN_API_KEY=
# EMAIL_MAILGUN_DOMAIN=
# EMAIL_MAILGUN_HOST=api.eu.mailgun.net   # ou api.mailgun.net pour US
# EMAIL_FROM=Physalis <noreply@example.com>

# --- OIDC GitHub Actions (cf. /api/deploy) ---
# Audience attendue dans le JWT OIDC. Doit matcher core.getIDToken('<audience>')
# cote workflow GitHub. Recommande : hostname public du vault.
# OIDC_AUDIENCE=vault.physalis.cloud

# --- Extension navigateur (cf. /api/plugin/*) ---
# Origin autorisee pour l'extension. Format chrome-extension://<id-stable>.
# L'ID est genere depuis la cle RSA dans manifest.json (key field) du repo
# secretvault-extension. Plusieurs valeurs separees par virgule autorisees
# (utile pour avoir dev + prod IDs en parallele).
# SI NON DEFINIE, tous les endpoints /api/plugin/* repondent 403 (kill switch).
# PLUGIN_ALLOWED_ORIGIN=chrome-extension://nkembdjkniapdjefmminilibmoeomhnc

# Duree de vie d'un PluginToken en secondes (defaut 14400 = 4h)
# PLUGIN_SESSION_TTL=14400
